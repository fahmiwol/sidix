# SIDIX — environment variables
# Salin file ini ke .env.local dan sesuaikan nilainya.
# Jangan commit .env.local ke git.

# URL backend brain_qa serve (Python FastAPI / subprocess bridge).
# Default: http://localhost:8765
VITE_BRAIN_QA_URL=http://localhost:8765

# APP_URL: URL di mana SIDIX diakses (untuk OAuth callback jika nanti multi-user).
# Di mode lokal, biarkan kosong.
# APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Settings → API Keys
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# SECRET KEY — hanya untuk backend Python di VPS, JANGAN di file ini
# Di server: export SUPABASE_SECRET_KEY="sb_secret_..."
