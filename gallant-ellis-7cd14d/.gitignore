# ============================================================
# SIDIX — .gitignore
# Rule: commit kode + corpus publik. JANGAN commit data
# auto-generated, model weights, private data, secrets.
# ============================================================

# ── Private & personal (NEVER commit) ───────────────────────
brain/private/
brain/SESSION_LOG*.md

# ── Model weights (terlalu besar, taruh di HuggingFace) ─────
apps/brain_qa/models/
*.safetensors
*.bin
*.gguf
*.ggml
sidix*.zip
sidix*.tar.gz

# ── Runtime data (auto-generated, rebuild dengan: python -m brain_qa index) ──
apps/brain_qa/.data/
apps/brain_qa/agent_workspace/
apps/brain_qa/qa_output.txt

# ── Generated media (audio, images, video — rebuilt on demand) ───────────────
data/generated/
data/

# ── Dokumen sprint pribadi (local only, jangan commit) ───────────────────────
SIDIX next Sprint plan*/

# ── Secrets & config lokal ───────────────────────────────────
.env
.env.*
!.env.sample

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
SIDIX_USER_UI/dist/
SIDIX_USER_UI/.env

# ── IDE & OS ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── IDE & AI assistants ──────────────────────────────────────
.cursor/
.claude/

# ── Notebooks (kaggle pull, output besar) ────────────────────
notebooks/kaggle_pulled/

# ── Logs & temp ──────────────────────────────────────────────
*.log
logs/
.backups/
*.tmp

# ── Internal context docs (jangan push — hanya lokal) ────────
docs/LIVING_LOG.md
docs/HANDOFF_*.md
docs/SIDIX_CHECKPOINT_*.md


.data/download_adapter.py
.data/kaggle_upload_cell.py
.data/kaggle_adapter/
# Sprint 15 visioner runtime output (auto-generated weekly, not for repo)
.data/visioner_reports/
.data/visioner_signals.jsonl
.data/visioner_weekly.log
.data/research_queue.jsonl
# Sprint 14 creative pipeline runtime output (per-brief artifacts)
.data/creative_briefs/

# ── VPS scripts (contain credentials via env var, internal use only) ─────────
scripts/vps_*.py
scripts/vps_check.py

# ── Dataset auto-generated by daily collector (regen tiap hari di VPS) ───────
dataset/id_sea/
